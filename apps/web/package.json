{
  "name": "@gcm/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "copy-cesium": "node scripts/copy-cesium-assets.mjs",
    "dev": "node scripts/copy-cesium-assets.mjs && vite",
    "build": "node scripts/copy-cesium-assets.mjs && tsc -b && vite build",
    "preview": "vite preview",
    "deploy:pages": "wrangler pages deploy dist --project-name=great-circle-mapper",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@gcm/shared": "workspace:*",
    "@turf/distance": "^7.2.0",
    "@turf/helpers": "^7.2.0",
    "cesium": "^1.142.0",
    "minisearch": "^7.1.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.10",
    "@types/geojson": "^7946.0.16",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "tailwindcss": "^4.1.10",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wrangler": "^4.86.0"
  }
}
